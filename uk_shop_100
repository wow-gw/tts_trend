<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TikTok Shop UK · Top 100 Brand Ranking Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg:#ffffff; --bg2:#f5f4f0; --bg3:#eeecea;
    --text:#3d3d3a; --texts:#73726c; --textt:#9e9d97;
    --border:rgba(0,0,0,0.10); --border2:rgba(0,0,0,0.18);
    --up:#1D9E75; --dn:#D85A30; --accent:#378ADD;
    --radius:8px; --radius-lg:12px;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg:#1e1e1c; --bg2:#2c2c2a; --bg3:#3a3a38;
      --text:#c2c0b6; --texts:#88877f; --textt:#5f5e5a;
      --border:rgba(255,255,255,0.09); --border2:rgba(255,255,255,0.18);
    }
  }
  body {
    font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Helvetica Neue',Arial,sans-serif;
    background:var(--bg); color:var(--text); padding:2rem 2.5rem; min-height:100vh;
  }
  h1 { font-size:18px; font-weight:600; color:var(--text); margin-bottom:4px; }
  .subtitle { font-size:12px; color:var(--texts); margin-bottom:1.75rem; }

  .sec-row { display:flex; align-items:center; gap:6px; margin-bottom:.65rem; }
  .sec-label { font-size:10.5px; font-weight:600; letter-spacing:.07em; text-transform:uppercase; color:var(--texts); }

  .info-icon {
    display:inline-flex; align-items:center; justify-content:center;
    width:15px; height:15px; border-radius:50%;
    background:var(--bg3); border:1px solid var(--border2);
    font-size:9px; color:var(--texts); cursor:default;
    position:relative; flex-shrink:0; transition:background .15s;
  }
  .info-icon:hover { background:var(--accent); color:#fff; border-color:var(--accent); }
  .info-icon .info-tip {
    display:none; position:absolute; left:22px; top:50%; transform:translateY(-50%);
    background:var(--text); color:var(--bg); border-radius:8px; padding:10px 13px;
    font-size:11px; font-weight:400; line-height:1.65; z-index:100;
    box-shadow:0 4px 16px rgba(0,0,0,.18); min-width:240px; max-width:320px;
    white-space:normal; letter-spacing:0; text-transform:none;
  }
  .info-icon .info-tip::before {
    content:''; position:absolute; left:-5px; top:50%; transform:translateY(-50%);
    border:5px solid transparent; border-right-color:var(--text); border-left:0;
  }
  .info-icon:hover .info-tip { display:block; }

  .mrow { display:grid; grid-template-columns:repeat(auto-fill,minmax(130px,1fr)); gap:8px; margin-bottom:1.5rem; }
  .mc { background:var(--bg2); border-radius:var(--radius); padding:.7rem .9rem; cursor:pointer; border:1.5px solid transparent; transition:border-color .15s,background .15s; }
  .mc:hover { background:var(--bg3); }
  .mc.active { border-color:var(--accent); background:var(--bg); }
  .mc-lbl { font-size:10px; color:var(--texts); margin-bottom:3px; }
  .mc-val { font-size:16px; font-weight:600; color:var(--text); line-height:1.15; }
  .mc-chg { font-size:10px; margin-top:3px; }
  .up { color:var(--up); } .dn { color:var(--dn); }

  .gmv-wrap { margin-bottom:1.75rem; background:var(--bg2); border-radius:var(--radius-lg); padding:1rem 1.25rem; }
  #gmvC-wrap { position:relative; width:100%; height:150px; margin-top:.5rem; }

  .ctrl { display:flex; align-items:center; gap:8px; margin-bottom:.6rem; flex-wrap:wrap; }
  .btn { font-size:12px; padding:5px 16px; border-radius:20px; border:1px solid var(--border2); background:transparent; cursor:pointer; color:var(--texts); transition:background .15s,color .15s; line-height:1.6; }
  .btn:hover { background:var(--bg3); }
  .btn.primary { background:var(--text); color:var(--bg); border-color:var(--text); }
  .btn.playing { background:var(--up); color:#fff; border-color:var(--up); }
  .spd { display:flex; align-items:center; gap:6px; font-size:11px; color:var(--texts); }
  .spd select { font-size:11px; border:1px solid var(--border2); border-radius:6px; padding:3px 7px; background:var(--bg); color:var(--text); cursor:pointer; }

  .usage-guide { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:.9rem; padding:10px 14px; background:var(--bg2); border-radius:var(--radius); border-left:3px solid var(--accent); }
  .usage-item { display:flex; align-items:center; gap:5px; font-size:11px; color:var(--texts); }
  .usage-sep { color:var(--border2); font-size:14px; }

  .search-wrap { display:flex; align-items:center; gap:8px; margin-bottom:.9rem; }
  .search-wrap input { font-size:12px; padding:5px 14px; border-radius:20px; border:1px solid var(--border2); background:var(--bg); color:var(--text); width:240px; outline:none; transition:border-color .15s; }
  .search-wrap input:focus { border-color:var(--accent); }
  .search-wrap input::placeholder { color:var(--textt); }

  .bump-wrap { position:relative; width:100%; }
  canvas#bc { display:block; width:100%; }

  .tt {
    position:absolute; background:var(--bg); border:1px solid var(--border2);
    border-radius:10px; padding:10px 14px; font-size:11px; pointer-events:none;
    opacity:0; transition:opacity .1s; z-index:30; min-width:220px;
    box-shadow:0 4px 20px rgba(0,0,0,.12);
  }
  .tt-name { font-weight:600; font-size:12.5px; margin-bottom:8px; }
  .tt-row { display:flex; justify-content:space-between; gap:12px; margin:2px 0; color:var(--texts); }
  .tt-v { color:var(--text); font-weight:600; }
  .tt-divider { border:none; border-top:1px solid var(--border); margin:6px 0; }
  .rev-bar-wrap { margin-top:7px; }
  .rev-bar-label { display:flex; justify-content:space-between; font-size:10px; color:var(--textt); margin-bottom:3px; }
  .rev-bar-track { width:100%; height:7px; background:var(--bg3); border-radius:4px; overflow:hidden; display:flex; }
  .rev-bar-seg { height:100%; transition:width .2s; }

  .leg-header { display:flex; align-items:center; justify-content:space-between; margin-top:1rem; margin-bottom:.4rem; }
  .leg-wrap { display:flex; flex-wrap:wrap; gap:4px; padding:1rem 1.25rem; background:var(--bg2); border-radius:var(--radius-lg); }
  .leg-item { display:flex; align-items:center; gap:5px; font-size:10.5px; color:var(--texts); cursor:pointer; padding:3px 8px; border-radius:20px; border:1px solid transparent; transition:background .12s,opacity .12s; user-select:none; line-height:1.5; }
  .leg-item:hover { background:var(--bg3); }
  .leg-item.off { opacity:.22; }
  .leg-item.hl  { border-color:var(--accent); background:var(--bg); }
  .leg-d { width:9px; height:9px; border-radius:50%; flex-shrink:0; }

  .source-badge {
    display:inline-flex; align-items:center; gap:6px;
    background:var(--bg2); border:1px solid var(--border2);
    border-radius:20px; padding:4px 12px;
    font-size:10.5px; color:var(--texts);
    margin-bottom:1.75rem;
  }
  .source-badge .dot { width:7px; height:7px; border-radius:50%; background:#ff4d4f; flex-shrink:0; }

  .footer-note { margin-top:1.5rem; padding:12px 16px; background:var(--bg2); border-radius:var(--radius); font-size:10.5px; color:var(--textt); line-height:1.8; }
  .footer-note strong { color:var(--texts); }

  @media (max-width:680px) {
    body { padding:1rem; }
    .mrow { grid-template-columns:repeat(3,minmax(0,1fr)); }
  }
</style>
</head>
